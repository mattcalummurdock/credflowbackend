# Wallets
DEPLOYER_PRIVATE_KEY=
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# Robinhood Chain Testnet (chain ID 46630)
RPC_ROBINHOOD=https://rpc.testnet.chain.robinhood.com
WS_ROBINHOOD=
NEXT_PUBLIC_ROBINHOOD_CHAIN_ID=46630
NEXT_PUBLIC_RPC_ROBINHOOD=https://rpc.testnet.chain.robinhood.com
# Optional; defaults to https://robinhood-testnet.g.alchemy.com/v2/$ALCHEMY_API_KEY
ALCHEMY_ROBINHOOD_RPC=

# Official Robinhood testnet tokens
USDG_ROBINHOOD=0x7E955252E15c84f5768B83c41a71F9eba181802F
WETH_ROBINHOOD=0x7943e237c7F95DA44E0301572D358911207852Fa
NEXT_PUBLIC_USDG_ADDRESS=0x7E955252E15c84f5768B83c41a71F9eba181802F
NEXT_PUBLIC_WETH_ADDRESS=0x7943e237c7F95DA44E0301572D358911207852Fa

# Oracle — Robinhood testnet has Data Streams, not legacy AggregatorV3 feeds.
# Leave CHAINLINK_ETH_USD_FEED empty to auto-deploy MockChainlinkFeed via npm run oracle:wire
CHAINLINK_ETH_USD_FEED=
MOCK_ETH_USD_PRICE=3000
PRICE_ORACLE=
SMOKE_BORROW_USDG=5
SMOKE_COLLATERAL_ETH=0.005
SMOKE_LOAN_DAYS=30
SMOKE_SCORE=624

# Spoke chains
RPC_ARBITRUM_SEPOLIA=
RPC_BASE_SEPOLIA=
# Aliases used by frontend loan-server.ts
RPC_ARBITRUM=
RPC_BASE=
WS_ARBITRUM_SEPOLIA=
# LayerZero V2 — Robinhood IS officially supported (see layerzero/config.json)
LAYERZERO_ENDPOINT_ROBINHOOD=0x3aCAAf60502791D199a5a5F0B173D78229eBFe32
LAYERZERO_ENDPOINT_ARBITRUM=0x6EDCE65403992e310A62460808c4b910D972f10f
LAYERZERO_ENDPOINT_BASE=0x6EDCE65403992e310A62460808c4b910D972f10f
LZ_EID_ROBINHOOD=40451
LZ_EID_ARBITRUM=40231
LZ_EID_BASE=40245
HUB_OAPP_ADDRESS=
ARBITRUM_OAPP_ADDRESS=
BASE_OAPP_ADDRESS=
# Spoke lending — prices synced from MAINNET Chainlink via scripts/chainlink.js (not mocks)
# On-chain: ChainlinkMirrorFeed on each spoke, updated by npm run sync:spoke:oracle:*
CHAINLINK_ETH_USD_FEED_ARBITRUM=0x639Fe6ab55C921f74e7fac1ee960C0B6293ba612
CHAINLINK_ETH_USD_FEED_BASE=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70
SPOKE_LENDING_FUND_USDC=50
SMOKE_BORROW_USDC=0.5
NEXT_PUBLIC_RPC_ARBITRUM_SEPOLIA=
NEXT_PUBLIC_RPC_BASE_SEPOLIA=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Data pipelines (Phase 2+) — multi-chain hub + spokes (see layerzero/config.json)
ALCHEMY_API_KEY=
RPC_ROBINHOOD=https://rpc.testnet.chain.robinhood.com
RPC_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc
RPC_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/${ALCHEMY_API_KEY}
ALCHEMY_ARBITRUM_SEPOLIA_RPC=
ALCHEMY_BASE_SEPOLIA_RPC=
USE_MOCK_DATA=0
# Morpho Blue indexer (Base Sepolia) — Etherscan API V2 topic-filtered event logs
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
MORPHO_FROM_BLOCK=37000000
# Base Sepolia Morpho prep — reuse public WETH/USD oracle (deploy often reverts on testnet RPC)
MORPHO_ORACLE_ADDRESS=0xc1b505f7ce2dc56abf5dc1495d6f66636937b125
CREDFLOW_LENDING_ADDRESS=
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
KNOWN_DEFAULTER_ADDRESSES=

# Post-default graph analysis (Phase 2) — npm run test:graph
GRAPH_ANALYSIS_LOG_LEVEL=INFO
# Cap BFS wallet visits (empty = unlimited; test:graph defaults to 15)
GRAPH_ANALYSIS_MAX_WALLETS=

# Scoring API (Phase 2)
SCORING_API_URL=http://localhost:8000
SCORING_API_HOST=0.0.0.0
SCORING_API_PORT=8000
# Reclaim bank balance + on-chain CredScoreEngine (set RECLAIM_ENABLED=1 to require proof)
# npm run ml:serve auto-starts ngrok and sets RECLAIM_CALLBACK_URL when RECLAIM_ENABLED=1
RECLAIM_ENABLED=1
USE_MOCK_RECLAIM=0
MOCK_RECLAIM_BALANCE_INR=100000
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
RECLAIM_PROVIDER_ID=
# Public URL Reclaim mobile app calls back to (e.g. ngrok or deployed API)
# Leave unset when using npm run ml:serve — ngrok URL is injected automatically.
# Manual run: https://<ngrok-host>/receive-proof
# RECLAIM_CALLBACK_URL=https://xxxx.ngrok-free.app/receive-proof
RECLAIM_SESSION_TTL_SEC=900
INR_PER_USD=86
RECLAIM_POLL_SEC=5
RECLAIM_POLL_MAX=180
CREDSCORE_ENGINE_ADDRESS=
# DEBUG for step-by-step terminal logs during /score
SCORING_API_LOG_LEVEL=INFO
# Aave spoke testnets — indexer uses Alchemy getAssetTransfers + receipt logs (ALCHEMY_API_KEY required)
# Base:     npm run base-sepolia:aave       pool 0x8bAB6d1b75f19e9eD9fCe8b9BD338844fF79aE27
# Arbitrum: npm run arbitrum-sepolia:aave   pool 0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff
# ARBITRUM_SEPOLIA_AAVE_SUPPLY_ETH=0.001  ARBITRUM_SEPOLIA_AAVE_BORROW_USDC=0.1
IPFS_API_URL=

# Groq agents (Phase 3)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GRAPH_ANALYSIS_DEPTH=1
GRAPH_ANALYSIS_MAX_WALLETS=15
LZ_NATIVE_FEE_PER_DST=500000000000000
MONITOR_FROM_BLOCK=
MONITOR_BLOCK_WINDOW=50000
# Optional public Base RPC for portfolio monitor (avoids Alchemy eth_getLogs limits)
MONITOR_RPC_BASE=https://sepolia.base.org
LIQUIDATION_GRACE_HOURS=48
UNDERWRITER_BORDERLINE_LOW=480
UNDERWRITER_BORDERLINE_HIGH=520

# Frontend / agents
FRONTEND_ORIGIN=http://localhost:3001
# FRONTEND_PRIVATE_KEY lives in frontend/.env (see frontend/.env.example)
# Leave empty — use npm run agents:serve instead of OZ Defender

# Agent scheduler (npm run agents:serve)
AGENT_MONITOR_INTERVAL_SEC=300
AGENT_RATES_INTERVAL_SEC=3600
AGENT_SYNC_INTERVAL_SEC=3600
AGENT_MONITOR_CHAINS=hub,arbitrum,base
# Per-run JSON logs for agents:serve + api_hook verification (default: logs/agent-runs/)
# AGENT_RUN_LOG_DIR=logs/agent-runs

# Hardhat
HARDHAT_FORK=true
LENDING_FUND_USDG=50
