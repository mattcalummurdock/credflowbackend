# Copy to Cloud Run env vars / Secret Manager. Do not commit real secrets.

# --- ML API ---
SCORING_API_HOST=0.0.0.0
# PORT is set by Cloud Run (8080). entrypoint.sh copies it to SCORING_API_PORT.
FRONTEND_ORIGIN=https://your-frontend.example
SCORING_API_LOG_LEVEL=INFO

# Public callback for Reclaim mobile proofs (use your Cloud Run service URL)
RECLAIM_ENABLED=1
RECLAIM_CALLBACK_URL=https://your-service-xyz.run.app/receive-proof
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
RECLAIM_PROVIDER_ID=

# --- Indexer / scoring data ---
ALCHEMY_API_KEY=
RPC_ROBINHOOD=https://rpc.testnet.chain.robinhood.com
RPC_ARBITRUM_SEPOLIA=
RPC_BASE_SEPOLIA=
USE_MOCK_DATA=0

# --- Agents (scheduler background process) ---
AGENT_PRIVATE_KEY=
RPC_ROBINHOOD=https://rpc.testnet.chain.robinhood.com
AGENT_MONITOR_INTERVAL_SEC=300
AGENT_RATES_INTERVAL_SEC=3600
AGENT_SYNC_INTERVAL_SEC=3600
AGENT_MONITOR_CHAINS=hub,arbitrum,base
MONITOR_RPC_BASE=https://sepolia.base.org

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

CREDSCORE_ENGINE_ADDRESS=
HUB_OAPP_ADDRESS=
